# Copia este archivo a .env.local y pega los valores del dashboard (Settings → API).
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu_anon_key_publica

# Sin estas variables (o con placeholders), la app usa solo localStorage.

# Gemini AI (free tier) — get your key at https://aistudio.google.com/app/apikey
# NOTE: No NEXT_PUBLIC_ prefix — this key is server-side only.
GEMINI_API_KEY=your_gemini_api_key_here