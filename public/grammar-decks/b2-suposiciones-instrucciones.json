      "tag": "Deducción presente",
      "title": "must / might / can't be",
      "lede": "Modales para deducir el presente según lo seguro que estés.",
      "blocks": [
        {
          "type": "rules",
          "rows": [
            { "key": "Seguro sí", "value": "She must be at work.", "highlights": ["must be"] },
