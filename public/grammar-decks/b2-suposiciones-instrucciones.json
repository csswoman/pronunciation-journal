            { "key": "Seguro no", "value": "That can't be right.", "highlights": ["can't be"] }
          ]
        }
      ],
      "tip": {
        "label": "Ojo:",
        "body": "para deducir lo negativo se usa can't, nunca mustn't."
      }
    },
