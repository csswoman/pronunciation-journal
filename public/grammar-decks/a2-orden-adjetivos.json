  "quiz": [
    {
      "q": "¿Cuál es el orden correcto?",
      "options": ["a red big old car", "a big old red car", "an old big red car", "a red old big car"],
      "answer": 1,
      "explain": "El orden correcto es tamaño → edad → color: big (tamaño) → old (edad) → red (color) → car."
    },
    {
      "q": "¿Dónde va un adjetivo de opinión como 'lovely'?",
      "options": ["Después del adjetivo de color", "Al final, antes del sustantivo", "Siempre primero, antes de todos los demás", "Solo después del verbo to be"],
      "answer": 2,
      "explain": "Los adjetivos de opinión (lovely, nice, awful, beautiful) siempre van primero: a lovely old wooden table."
    },
    {
      "q": "¿Cuál es correcta?",
      "options": ["She has Italian beautiful long hair.", "She has beautiful long Italian hair.", "She has long Italian beautiful hair.", "She has beautiful Italian long hair."],
      "answer": 1,
      "explain": "Opinión → largo (tamaño) → origen: beautiful (opinión) → long (tamaño) → Italian (origen) → hair."
    }
