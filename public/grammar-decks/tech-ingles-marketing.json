    {
      "id": "mk-trends",
      "tag": "Datos",
      "title": "Describir tendencias",
      "lede": "Verbos y adverbios para presentar métricas y su evolución en informes.",
      "blocks": [
        {
          "type": "rules",
          "rows": [
            { "key": "Subir", "value": "rise · increase · soar · climb", "highlights": ["soar"] },
            { "key": "Bajar", "value": "fall · drop · decline · plummet", "highlights": ["plummet"] },
            { "key": "Grado", "value": "sharply · slightly · steadily", "highlights": ["sharply"] }
          ]
        }
      ]
    },
    {
      "id": "mk-comparatives",
      "tag": "Comparar",
      "title": "Comparar campañas",
      "lede": "Los comparativos y superlativos sirven para contrastar resultados y opciones.",
      "blocks": [
        {
          "type": "pairs",
          "lines": [
            { "variant": "good", "text": "Campaign A performed better than B.", "note": "comparativo" },
            { "variant": "good", "text": "This was our most successful launch.", "note": "superlativo" },
            { "variant": "good", "text": "Engagement was twice as high.", "note": "twice as ... as" },
            { "variant": "good", "text": "Conversions rose by 30%.", "note": "rise by + cifra" }
          ]
        }
      ]
    },
    {
