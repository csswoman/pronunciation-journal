            { "key": "Impacto", "value": "How is that affecting your team?", "highlights": ["How is that affecting"] }
          ]
        }
      ],
      "tip": {
        "label": "Clave:",
        "body": "pregunta y escucha más de lo que hablas; vende sobre lo que el cliente necesita."
      }
    },
    {
