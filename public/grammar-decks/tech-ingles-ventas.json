      "lede": "Preguntas abiertas que descubren los problemas del cliente antes de vender.",
      "blocks": [
        {
          "type": "rules",
          "rows": [
            { "key": "Situación", "value": "What's your current process?", "highlights": ["What's your current process?"] },
