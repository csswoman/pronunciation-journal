            { "key": "Prueba", "value": "Our clients have seen a 40% increase.", "highlights": ["have seen"] }
          ]
        }
      ]
    },
    {
      "id": "sa-objections",
      "tag": "Objeciones",
      "title": "Manejar objeciones",
      "lede": "Reconoce la objeción antes de responderla. No discutas: reencuadra.",
      "blocks": [
        {
          "type": "pairs",
          "lines": [
            { "variant": "good", "text": "I understand your concern.", "note": "reconocer primero" },
            { "variant": "good", "text": "That's a fair point. Let me explain...", "note": "validar y reencuadrar" },
            { "variant": "bad", "text": "No, you're wrong about that.", "note": "evítalo" },
            { "variant": "good", "text": "Many clients felt the same, until...", "note": "feel-felt-found" }
          ]
        }
      ]
    },
    {
