      "tag": "Negociar",
      "title": "Precio y condiciones",
      "lede": "El condicional es la herramienta clave: ofrece concesiones a cambio de algo.",
      "blocks": [
        {
          "type": "rules",
          "rows": [
            { "key": "Condicional", "value": "If you sign today, we can offer 10% off.", "highlights": ["If you sign today"] },
            { "key": "Ceder", "value": "We could be flexible on...", "highlights": ["We could be flexible"] },
            { "key": "A cambio", "value": "...in exchange for a longer contract.", "highlights": ["in exchange for"] }
          ]
        }
      ]
